<?xml version="1.0" encoding="utf-8"?>
<!-- The 1024px art inset within the adaptive-icon safe zone so launcher masks
     (circle/squircle) don't crop the label. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:drawable="@drawable/ic_launcher_art"
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp" />
</layer-list>
